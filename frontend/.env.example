# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized JavaScript origins: http://localhost:5173, https://yourdomain.com
# 5. Copy the Client ID below

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Optional: API Base URL (defaults to http://localhost:3000/api if not set)
# VITE_API_URL=http://localhost:3000/api
